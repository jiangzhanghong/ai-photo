page {
  min-height: 100vh;
  background: #f3f5f2;
  color: #1d2823;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  display: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
}

.card {
  border: 1rpx solid #e0e6e2;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 59, 44, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #1c2822;
  font-size: 30rpx;
  font-weight: 700;
}

.muted {
  color: #7b8580;
  font-size: 24rpx;
}

.primary-btn {
  height: 88rpx;
  display: grid;
  place-items: center;
  border-radius: 12rpx;
  background: #103b2c;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.ghost-btn {
  height: 64rpx;
  display: grid;
  place-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #d6dfda;
  border-radius: 999rpx;
  background: #fff;
  color: #40504a;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef4f0;
  color: #315446;
  font-size: 22rpx;
}

.image {
  display: block;
  width: 100%;
  height: 100%;
}
