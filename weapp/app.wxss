page {
  min-height: 100vh;
  background: #f8f4ed;
  color: #1d2823;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: inherit;
  font: inherit;
}

button::after {
  display: none;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 52rpx;
}

.card {
  border: 1rpx solid rgba(16, 59, 44, 0.06);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 32rpx rgba(16, 59, 44, 0.06);
}

.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  color: #1c2822;
  font-size: 30rpx;
  font-weight: 700;
}

.muted {
  color: #7b8580;
  font-size: 24rpx;
}

.primary-btn {
  height: 88rpx;
  display: grid;
  place-items: center;
  border-radius: 22rpx;
  background: #103b2c;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.ghost-btn {
  height: 64rpx;
  display: grid;
  place-items: center;
  padding: 0 22rpx;
  border: 1rpx solid #d6dfda;
  border-radius: 999rpx;
  background: #fff;
  color: #40504a;
  font-size: 24rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #eef4f0;
  color: #315446;
  font-size: 22rpx;
}

.image {
  display: block;
  width: 100%;
  height: 100%;
}

.phone-shell {
  overflow: hidden;
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 34rpx rgba(20, 49, 36, 0.08);
}

.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  margin-bottom: 18rpx;
}

.custom-nav-title {
  color: #1d2823;
  font-size: 38rpx;
  font-weight: 700;
}

.custom-nav-action {
  color: #7f8782;
  font-size: 24rpx;
}
