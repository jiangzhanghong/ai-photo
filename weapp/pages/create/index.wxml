<view class="page template-page" style="padding-top: {{safeTop}}px;">
  <view class="custom-nav" style="padding-right: {{capsuleGap}}px;">
    <text class="custom-nav-title">模板广场</text>
    <view class="coin-box">
      <text class="coin-label">分</text>
      <text class="coin-value">{{user ? creditBalance : '--'}}</text>
    </view>
  </view>

  <view class="search-shell">
    <text class="search-icon">⌕</text>
    <input class="search-input" placeholder="搜索你喜欢的模板" value="{{searchValue}}" bindinput="onSearchInput" />
  </view>

  <scroll-view scroll-x class="category-scroll">
    <view class="category-track">
      <button
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-chip {{item === activeCategory ? 'active' : ''}}"
        data-value="{{item}}"
        bindtap="selectCategory"
      >
        {{item}}
      </button>
    </view>
  </scroll-view>

  <view wx:if="{{loadingPrompts}}" class="template-grid">
    <view wx:for="{{skeletonItems}}" wx:key="*this" class="template-card skeleton-card">
      <view class="template-cover skeleton-block"></view>
      <view class="template-body">
        <view class="skeleton-line title-line"></view>
        <view class="skeleton-line"></view>
        <view class="skeleton-line short-line"></view>
      </view>
    </view>
  </view>

  <view wx:elif="{{promptLoadFailed}}" class="card empty-card">
    <text class="empty-title">模板加载失败</text>
    <text class="empty-desc">网络或服务异常，稍后重试。</text>
    <button class="retry-btn" bindtap="retryLoadPrompts">重新加载</button>
  </view>

  <view wx:elif="{{filteredTemplates.length}}" class="template-grid">
    <button
      wx:for="{{filteredTemplates}}"
      wx:key="id"
      class="template-card {{item.id === selectedTemplateId || item.promptId === selectedTemplateId ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="selectTemplate"
    >
      <view class="template-cover-wrap">
        <image class="template-cover" mode="aspectFill" src="{{item.imageUrl}}" />
        <text wx:if="{{item.badge}}" class="template-badge">{{item.badge}}</text>
        <text wx:if="{{item.id === selectedTemplateId || item.promptId === selectedTemplateId}}" class="using-badge">使用中</text>
      </view>
      <view class="template-body">
        <text class="template-title">{{item.title}}</text>
        <text class="template-subtitle">{{item.subtitle}}</text>
        <view class="template-meta">
          <text class="template-cost">{{item.creditCost}} 积分</text>
          <text class="template-go">{{item.id === selectedTemplateId || item.promptId === selectedTemplateId ? '已选择' : '使用'}}</text>
        </view>
      </view>
    </button>
  </view>

  <view wx:else class="card empty-card">
    <text class="empty-title">没有找到匹配模板</text>
    <text class="empty-desc">换个关键词，或者切回“推荐”看看。</text>
  </view>

  <view wx:if="{{previewVisible}}" class="template-preview-mask" catchtap="closeTemplatePreview">
    <view class="template-preview-sheet" catchtap="noop">
      <view class="template-preview-head">
        <view>
          <view class="template-preview-kicker">{{previewTemplate.category || previewTemplate.subtitle}}</view>
          <view class="template-preview-title">{{previewTemplate.title}}</view>
        </view>
        <button class="template-preview-close" bindtap="closeTemplatePreview">×</button>
      </view>
      <scroll-view scroll-x class="template-preview-scroll">
        <view class="template-preview-track">
          <image
            wx:for="{{previewImages}}"
            wx:key="*this"
            class="template-preview-image"
            mode="aspectFill"
            src="{{item}}"
          />
        </view>
      </scroll-view>
      <view class="template-preview-desc">{{previewTemplate.promptText}}</view>
      <view class="template-preview-tags">
        <text wx:if="{{previewTemplate.defaultRatio}}" class="template-preview-tag">{{previewTemplate.defaultRatio === 'adaptive' ? '智能比例' : previewTemplate.defaultRatio}}</text>
        <text wx:if="{{previewTemplate.defaultResolution}}" class="template-preview-tag">{{previewTemplate.defaultResolution}}</text>
        <text class="template-preview-tag">{{previewTemplate.creditCost}} 积分/张</text>
        <text wx:for="{{previewTemplate.categoryTags}}" wx:key="*this" class="template-preview-tag">{{item}}</text>
      </view>
      <button class="template-preview-use" bindtap="usePreviewTemplate">使用这个模板</button>
    </view>
  </view>
</view>
