<view class="page template-page" style="padding-top: {{safeTop}}px;">
  <view class="custom-nav">
    <text class="custom-nav-title">模板广场</text>
    <view class="coin-box">
      <text class="coin-label">P</text>
      <text class="coin-value">{{creditBalance}}</text>
    </view>
  </view>

  <view class="search-shell">
    <input
      class="search-input"
      placeholder="搜索你喜欢的模板"
      value="{{searchValue}}"
      bindinput="onSearchInput"
    />
  </view>

  <scroll-view scroll-x class="category-scroll">
    <view class="category-track">
      <button
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-chip {{item === activeCategory ? 'active' : ''}}"
        data-value="{{item}}"
        bindtap="selectCategory"
      >
        {{item}}
      </button>
    </view>
  </scroll-view>

  <view class="template-grid">
    <button
      wx:for="{{filteredTemplates}}"
      wx:key="id"
      class="template-card"
      data-id="{{item.id}}"
      bindtap="selectTemplate"
    >
      <view class="template-cover-wrap">
        <image class="template-cover" mode="aspectFill" src="{{item.imageUrl}}" />
        <text wx:if="{{item.badge}}" class="template-badge">{{item.badge}}</text>
      </view>
      <view class="template-body">
        <text class="template-title">{{item.title}}</text>
        <text class="template-subtitle">{{item.subtitle}}</text>
        <view class="template-meta">
          <text class="template-cost">P {{item.creditCost}}</text>
          <text class="template-go">使用</text>
        </view>
      </view>
    </button>
  </view>
</view>
