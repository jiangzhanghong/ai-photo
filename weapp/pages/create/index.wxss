.template-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(219, 199, 164, 0.18), transparent 40%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.coin-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 234, 196, 0.52);
}

.coin-label {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #e8bc66;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.coin-value {
  color: #6d4d11;
  font-size: 26rpx;
  font-weight: 700;
}

.search-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 12rpx 24rpx rgba(24, 51, 39, 0.05);
}

.search-icon {
  color: #a2aba5;
  font-size: 26rpx;
}

.search-input {
  flex: 1;
  color: #1f2824;
  font-size: 26rpx;
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 10rpx;
}

.category-chip {
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #6e7972;
  font-size: 24rpx;
  line-height: 54rpx;
}

.category-chip.active {
  background: #143d2f;
  color: #ffffff;
  font-weight: 700;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx 18rpx;
  margin-top: 24rpx;
}

.template-card {
  overflow: hidden;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 28rpx rgba(20, 51, 38, 0.06);
  text-align: left;
}

.template-card.active {
  border-color: #143d2f;
  box-shadow: 0 16rpx 34rpx rgba(20, 61, 47, 0.14);
}

.template-cover-wrap {
  position: relative;
}

.template-cover {
  width: 100%;
  height: 278rpx;
  background: #e9e4db;
}

.template-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f39f72 0%, #e57e47 100%);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}

.using-badge {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(20, 61, 47, 0.92);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}

.template-body {
  display: grid;
  gap: 10rpx;
  padding: 16rpx 16rpx 18rpx;
}

.template-title {
  overflow: hidden;
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-subtitle {
  min-height: 58rpx;
  color: #7a847e;
  font-size: 22rpx;
  line-height: 1.4;
}

.template-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.template-cost {
  color: #d0993f;
  font-size: 24rpx;
  font-weight: 700;
}

.template-go {
  color: #143d2f;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-card {
  display: grid;
  gap: 12rpx;
  margin-top: 28rpx;
  padding: 42rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
}

.empty-desc {
  color: #7a847e;
  font-size: 24rpx;
}

.retry-btn {
  width: 220rpx;
  height: 70rpx;
  margin: 12rpx auto 0;
  border-radius: 999rpx;
  background: #143d2f;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 70rpx;
  text-align: center;
}

.skeleton-card {
  pointer-events: none;
}

.skeleton-block,
.skeleton-line {
  background: linear-gradient(90deg, #eee8dd 0%, #f8f4ec 48%, #eee8dd 100%);
  background-size: 300% 100%;
  animation: skeleton-wave 1.4s ease-in-out infinite;
}

.skeleton-line {
  width: 100%;
  height: 24rpx;
  border-radius: 999rpx;
}

.title-line {
  width: 66%;
  height: 30rpx;
}

.short-line {
  width: 42%;
}

@keyframes skeleton-wave {
  0% {
    background-position: 100% 0;
  }

  100% {
    background-position: 0 0;
  }
}
