.template-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(219, 199, 164, 0.18), transparent 40%),
    linear-gradient(180deg, #fbf7f0 0%, #f5f1ea 100%);
}

.coin-box {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 234, 196, 0.52);
}

.coin-label {
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  background: #e8bc66;
  color: #ffffff;
  font-size: 18rpx;
  line-height: 30rpx;
  text-align: center;
}

.coin-value {
  color: #6d4d11;
  font-size: 26rpx;
  font-weight: 700;
}

.search-shell {
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 12rpx 24rpx rgba(24, 51, 39, 0.05);
}

.search-input {
  color: #1f2824;
  font-size: 26rpx;
}

.category-scroll {
  margin-top: 20rpx;
  white-space: nowrap;
}

.category-track {
  display: inline-flex;
  gap: 12rpx;
  padding-right: 10rpx;
}

.category-chip {
  height: 54rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #6e7972;
  font-size: 24rpx;
  line-height: 54rpx;
}

.category-chip.active {
  background: #143d2f;
  color: #ffffff;
  font-weight: 700;
}

.template-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx 18rpx;
  margin-top: 24rpx;
}

.template-card {
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 14rpx 28rpx rgba(20, 51, 38, 0.06);
  text-align: left;
}

.template-cover-wrap {
  position: relative;
}

.template-cover {
  width: 100%;
  height: 268rpx;
  background: #e9e4db;
}

.template-badge {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f39f72 0%, #e57e47 100%);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 1;
}

.template-body {
  display: grid;
  gap: 8rpx;
  padding: 18rpx 18rpx 20rpx;
}

.template-title {
  overflow: hidden;
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.template-subtitle {
  min-height: 60rpx;
  color: #7a847e;
  font-size: 22rpx;
  line-height: 1.4;
}

.template-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 6rpx;
}

.template-cost {
  color: #d0993f;
  font-size: 24rpx;
  font-weight: 700;
}

.template-go {
  color: #143d2f;
  font-size: 24rpx;
}
