.records-page {
  padding-bottom: 120rpx;
}

.empty-card {
  display: grid;
  gap: 22rpx;
  padding: 36rpx 28rpx;
  color: #53615b;
  text-align: center;
}

.task-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.task-card {
  overflow: hidden;
  text-align: left;
}

.task-cover {
  width: 100%;
  height: 342rpx;
  display: grid;
  place-items: center;
  background: #e9efeb;
  color: #708078;
  font-size: 24rpx;
}

.task-body {
  display: grid;
  gap: 10rpx;
  padding: 16rpx;
}

.task-title {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #1d2823;
  font-size: 26rpx;
  font-weight: 700;
}

.task-meta {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  color: #76847d;
  font-size: 22rpx;
}
