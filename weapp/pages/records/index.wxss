.works-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(221, 198, 162, 0.16), transparent 42%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.login-empty {
  display: grid;
  gap: 18rpx;
  padding: 40rpx 28rpx;
  text-align: center;
}

.login-empty-title {
  color: #1f2824;
  font-size: 30rpx;
  font-weight: 700;
}

.login-empty-desc {
  color: #7c847f;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-empty-btn {
  height: 88rpx;
  margin-top: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.filter-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.filter-chip {
  min-width: 112rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #808983;
  font-size: 24rpx;
  line-height: 56rpx;
}

.filter-chip.active {
  background: #143d2f;
  color: #ffffff;
  font-weight: 700;
}

.works-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.work-card {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 14rpx 28rpx rgba(20, 51, 38, 0.06);
  text-align: left;
}

.work-card.failed {
  background: rgba(255, 247, 242, 0.95);
}

.work-card.processing,
.work-card.queued {
  background: rgba(255, 252, 244, 0.95);
}

.work-image-wrap {
  position: relative;
}

.work-image {
  width: 100%;
  height: 252rpx;
  background: #e9e4db;
}

.work-action {
  position: absolute;
  right: 14rpx;
  bottom: 14rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #4d544f;
  font-size: 22rpx;
}

.work-status {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(20, 61, 47, 0.88);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
}

.work-status.failed {
  background: rgba(176, 70, 45, 0.90);
}

.work-status.processing,
.work-status.queued {
  background: rgba(194, 138, 46, 0.92);
}

.work-body {
  display: grid;
  gap: 8rpx;
  padding: 18rpx;
}

.work-title {
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
}

.work-time {
  color: #78827c;
  font-size: 22rpx;
}

.work-meta {
  display: flex;
  justify-content: space-between;
  gap: 10rpx;
  color: #7c847f;
  font-size: 22rpx;
}

.work-hint {
  color: #9a6b25;
  font-size: 21rpx;
}

.works-empty {
  display: grid;
  gap: 16rpx;
  padding: 42rpx 28rpx;
  text-align: center;
}

.works-empty-title {
  color: #1f2824;
  font-size: 30rpx;
  font-weight: 700;
}

.works-empty-desc {
  color: #7c847f;
  font-size: 24rpx;
  line-height: 1.6;
}

.works-empty-btn {
  width: 220rpx;
  height: 72rpx;
  margin: 8rpx auto 0;
  border-radius: 999rpx;
  background: #143d2f;
  color: #ffffff;
  font-size: 26rpx;
  line-height: 72rpx;
  text-align: center;
}
