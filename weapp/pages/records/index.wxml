<view class="page works-page" style="padding-top: {{safeTop}}px;">
  <view class="custom-nav" style="padding-right: {{capsuleGap}}px;">
    <text class="custom-nav-title">作品</text>
  </view>

  <view wx:if="{{needsLogin}}" class="card login-empty">
    <text class="login-empty-title">登录后查看作品记录</text>
    <text class="login-empty-desc">生成结果、保存记录和下载进度会同步到你的账号。</text>
    <button class="login-empty-btn" bindtap="goLogin">去登录</button>
  </view>

  <block wx:else>
    <view class="filter-row">
      <button
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-chip {{item.key === activeFilter ? 'active' : ''}}"
        data-value="{{item.key}}"
        bindtap="selectFilter"
      >
        {{item.label}}
      </button>
    </view>

    <view wx:if="{{loadingWorks}}" class="card works-empty">
      <text class="works-empty-title">正在加载作品</text>
      <text class="works-empty-desc">正在同步生成中、已完成和失败的任务。</text>
    </view>

    <view wx:elif="{{loadFailed}}" class="card works-empty">
      <text class="works-empty-title">作品加载失败</text>
      <text class="works-empty-desc">网络或服务暂时异常，请稍后重试。</text>
      <button class="works-empty-btn" bindtap="retryLoadWorks">重新加载</button>
    </view>

    <view wx:elif="{{displayWorks.length}}" class="works-grid">
      <button
        wx:for="{{displayWorks}}"
        wx:key="id"
        class="work-card {{item.status}}"
        data-id="{{item.id}}"
        bindtap="openWork"
      >
        <view class="work-image-wrap">
          <image class="work-image" mode="aspectFill" src="{{item.imageUrl}}" />
          <text class="work-status {{item.status}}">{{item.statusLabel}}</text>
          <button
            wx:if="{{item.buttonText}}"
            class="work-action"
            data-id="{{item.id}}"
            catchtap="openWork"
          >
            {{item.buttonText}}
          </button>
        </view>
        <view class="work-body">
          <text class="work-title">{{item.title}}</text>
          <text class="work-time">{{item.createdLabel}}</text>
          <view class="work-meta">
            <text>{{item.ratio}}</text>
            <text>消耗 {{item.creditCost}} 积分</text>
          </view>
          <text class="work-hint">{{item.statusHint}}</text>
        </view>
      </button>
    </view>

    <view wx:else class="card works-empty">
      <text class="works-empty-title">暂无作品</text>
      <text class="works-empty-desc">生成成功、生成中和失败任务都会按真实状态展示在这里。</text>
      <button class="works-empty-btn" bindtap="goCreate">去选模板</button>
    </view>
  </block>
</view>
