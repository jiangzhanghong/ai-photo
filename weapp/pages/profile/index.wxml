<view class="page profile-page" style="padding-top: {{safeTop}}px;">
  <view class="custom-nav" style="padding-right: {{capsuleGap}}px;">
    <text class="custom-nav-title">我的</text>
    <text class="custom-nav-action">设置</text>
  </view>

  <block wx:if="{{user}}">
    <view class="profile-head card">
      <image class="profile-avatar" mode="aspectFill" src="{{avatarUrl}}" />
      <view class="profile-copy">
        <view class="profile-name-row">
          <text class="profile-name">{{displayName}}</text>
          <text class="profile-edit">编辑</text>
        </view>
        <text class="profile-desc">用镜头记录最美好瞬间</text>
      </view>
    </view>

    <view class="card stats-card">
      <view class="stats-item primary">
        <text class="stats-item-label">我的积分</text>
        <text class="stats-main-value">{{creditBalance}}</text>
      </view>
      <view class="stats-item">
        <text class="stats-item-label">累计充值</text>
        <text class="stats-item-value">{{cumulativeRecharge}} 积分</text>
      </view>
      <view class="stats-item">
        <text class="stats-item-label">累计消耗</text>
        <text class="stats-item-value">{{cumulativeSpend}} 积分</text>
      </view>
    </view>

    <view class="card action-list">
      <button
        wx:for="{{actions}}"
        wx:key="key"
        class="action-item {{item.key === 'logout' ? 'logout' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleAction"
      >
        <view class="action-main">
          <text class="action-icon {{item.iconText}}-icon"></text>
          <text class="action-label">{{item.label}}</text>
        </view>
        <view class="action-side">
          <text wx:if="{{item.value}}" class="action-value">{{item.value}}</text>
          <text class="action-arrow">›</text>
        </view>
      </button>
    </view>
  </block>

  <block wx:else>
    <view class="login-head card">
      <image class="profile-avatar" mode="aspectFill" src="{{avatarUrl}}" />
      <view class="profile-copy">
        <text class="profile-name">登录后查看积分与作品</text>
        <text class="profile-desc">默认微信授权登录，也支持账号密码登录</text>
      </view>
    </view>

    <view class="card login-panel">
      <view class="login-switch">
        <button
          class="login-switch-item {{loginMode === 'wechat' ? 'active' : ''}}"
          data-mode="wechat"
          bindtap="switchLoginMode"
        >
          微信登录
        </button>
        <button
          class="login-switch-item {{loginMode === 'account' ? 'active' : ''}}"
          data-mode="account"
          bindtap="switchLoginMode"
        >
          账号登录
        </button>
      </view>

      <button
        wx:if="{{loginMode === 'wechat'}}"
        class="login-primary-btn"
        loading="{{loggingIn}}"
        bindtap="loginWithWechat"
      >
        微信授权登录
      </button>

      <view wx:else class="account-form">
        <input class="auth-input" placeholder="请输入账号" value="{{account}}" bindinput="onAccountInput" />
        <input
          class="auth-input"
          password
          placeholder="请输入密码"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
        <button class="login-primary-btn" loading="{{loggingIn}}" bindtap="loginWithAccount">
          账号登录
        </button>
      </view>
    </view>
  </block>
</view>
