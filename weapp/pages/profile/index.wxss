.profile-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(223, 199, 160, 0.16), transparent 42%),
    linear-gradient(180deg, #fbf7f0 0%, #f5f1ea 100%);
}

.profile-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e9e4db;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name {
  color: #1f2824;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-desc,
.stats-item-label,
.action-value {
  color: #7c867f;
  font-size: 22rpx;
}

.profile-desc {
  display: block;
  margin-top: 10rpx;
}

.stats-card {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 28rpx;
}

.stats-main {
  min-width: 160rpx;
}

.stats-label {
  color: #5c6761;
  font-size: 24rpx;
}

.stats-value {
  margin-top: 16rpx;
  color: #1f2824;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
}

.stats-side {
  display: grid;
  flex: 1;
  gap: 16rpx;
}

.stats-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.stats-item-value {
  color: #1f2824;
  font-size: 26rpx;
  font-weight: 700;
}

.action-list {
  margin-top: 22rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-bottom: 1rpx solid rgba(16, 59, 44, 0.06);
  background: transparent;
}

.action-item:last-child {
  border-bottom: 0;
}

.action-label {
  color: #1f2824;
  font-size: 28rpx;
}

.action-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-arrow {
  color: #b3bbb6;
  font-size: 30rpx;
}
