.profile-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(223, 199, 160, 0.16), transparent 42%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.profile-head,
.login-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e9e4db;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-name {
  color: #1f2824;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-edit {
  color: #c79236;
  font-size: 22rpx;
}

.profile-desc,
.stats-item-label,
.action-value {
  color: #7c867f;
  font-size: 22rpx;
}

.profile-desc {
  display: block;
  margin-top: 10rpx;
}

.stats-card {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 28rpx;
}

.stats-item {
  display: grid;
  gap: 14rpx;
  align-content: start;
}

.stats-item.primary {
  padding-right: 14rpx;
  border-right: 1rpx solid rgba(16, 59, 44, 0.08);
}

.stats-main-value {
  color: #1f2824;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
}

.stats-item-value {
  color: #1f2824;
  font-size: 26rpx;
  font-weight: 700;
}

.action-list {
  margin-top: 22rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-bottom: 1rpx solid rgba(16, 59, 44, 0.06);
  background: transparent;
}

.action-item:last-child {
  border-bottom: 0;
}

.action-item.logout .action-icon,
.action-item.logout .action-label {
  color: #cb7d38;
}

.action-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.action-icon {
  display: inline-grid;
  place-items: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: rgba(199, 146, 54, 0.10);
  color: #c79236;
  font-size: 22rpx;
  font-weight: 700;
}

.action-label {
  color: #1f2824;
  font-size: 28rpx;
}

.action-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-arrow {
  color: #b3bbb6;
  font-size: 30rpx;
}

.login-panel {
  margin-top: 22rpx;
  padding: 24rpx;
}

.login-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.login-switch-item {
  height: 76rpx;
  border-radius: 20rpx;
  background: #f5f1ea;
  color: #68736d;
  font-size: 28rpx;
  line-height: 76rpx;
  text-align: center;
}

.login-switch-item.active {
  background: #143d2f;
  color: #ffffff;
  font-weight: 700;
}

.login-primary-btn {
  height: 88rpx;
  margin-top: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.account-form {
  display: grid;
  gap: 18rpx;
  margin-top: 22rpx;
}

.auth-input {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f7f4ee;
  color: #1f2824;
  font-size: 26rpx;
}
