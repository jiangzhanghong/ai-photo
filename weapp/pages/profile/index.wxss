.profile-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(223, 199, 160, 0.16), transparent 42%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.profile-head,
.login-head {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 28rpx;
}

.profile-avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #e9e4db;
}

.profile-copy {
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-name {
  color: #1f2824;
  font-size: 36rpx;
  font-weight: 700;
}

.profile-edit {
  color: #c79236;
  font-size: 22rpx;
}

.profile-desc,
.stats-item-label,
.action-value {
  color: #7c867f;
  font-size: 22rpx;
}

.profile-desc {
  display: block;
  margin-top: 10rpx;
}

.stats-card {
  display: grid;
  grid-template-columns: 1.2fr 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
  padding: 28rpx;
}

.stats-item {
  display: grid;
  gap: 14rpx;
  align-content: start;
}

.stats-item.primary {
  padding-right: 14rpx;
  border-right: 1rpx solid rgba(16, 59, 44, 0.08);
}

.stats-main-value {
  color: #1f2824;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1;
}

.stats-item-value {
  color: #1f2824;
  font-size: 26rpx;
  font-weight: 700;
}

.action-list {
  margin-top: 22rpx;
  overflow: hidden;
}

.action-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 96rpx;
  padding: 0 26rpx;
  border-bottom: 1rpx solid rgba(16, 59, 44, 0.06);
  background: transparent;
}

.action-item:last-child {
  border-bottom: 0;
}

.action-item.logout .action-icon,
.action-item.logout .action-label {
  color: #cb7d38;
}

.action-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.action-icon {
  position: relative;
  display: inline-grid;
  place-items: center;
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background: rgba(199, 146, 54, 0.10);
  color: #c79236;
  font-size: 22rpx;
  font-weight: 700;
}

.action-icon::before,
.action-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.coin-icon::before {
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
}

.doc-icon::before {
  width: 20rpx;
  height: 26rpx;
  border: 4rpx solid currentColor;
  border-radius: 5rpx;
}

.doc-icon::after,
.list-icon::before {
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 0 9rpx 0 currentColor, 0 18rpx 0 currentColor;
}

.chat-icon::before {
  width: 26rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 8rpx;
}

.chat-icon::after {
  left: 22rpx;
  bottom: 8rpx;
  width: 10rpx;
  height: 10rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-20deg);
}

.shield-icon::before {
  width: 24rpx;
  height: 28rpx;
  border: 4rpx solid currentColor;
  border-radius: 12rpx 12rpx 14rpx 14rpx;
}

.lock-icon::before {
  width: 24rpx;
  height: 18rpx;
  top: 17rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.lock-icon::after {
  width: 16rpx;
  height: 14rpx;
  top: 7rpx;
  border: 4rpx solid currentColor;
  border-bottom: 0;
  border-radius: 10rpx 10rpx 0 0;
}

.mail-icon::before {
  width: 26rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 6rpx;
}

.mail-icon::after {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  transform: rotate(-45deg);
}

.logout-icon::before {
  width: 20rpx;
  height: 22rpx;
  left: 8rpx;
  border: 4rpx solid currentColor;
  border-right: 0;
  border-radius: 6rpx 0 0 6rpx;
}

.logout-icon::after {
  right: 8rpx;
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  box-shadow: 6rpx -6rpx 0 -2rpx currentColor, 6rpx 6rpx 0 -2rpx currentColor;
}

.action-label {
  color: #1f2824;
  font-size: 28rpx;
}

.action-side {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.action-arrow {
  color: #b3bbb6;
  font-size: 30rpx;
}

.login-panel {
  margin-top: 22rpx;
  padding: 24rpx;
}

.login-primary-btn {
  height: 88rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.login-safe-note {
  display: block;
  margin-top: 18rpx;
  color: #7b8580;
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}
