.result-page {
  padding-bottom: 120rpx;
}

.result-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.title {
  color: #1d2823;
  font-size: 34rpx;
  font-weight: 800;
}

.message-card,
.pending-card {
  display: grid;
  gap: 12rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  color: #53615b;
  text-align: center;
}

.message-card.failed {
  color: #8a3b2b;
  background: #fff4ef;
}

.message-title,
.pending-title {
  color: #1d2823;
  font-size: 30rpx;
  font-weight: 700;
}

.refund-note {
  color: #9a6b25;
  font-size: 23rpx;
  line-height: 1.5;
}

.status-summary {
  display: grid;
  gap: 8rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 22rpx;
  border-radius: 22rpx;
  font-size: 24rpx;
}

.status-summary text:first-child {
  font-size: 28rpx;
  font-weight: 700;
}

.status-summary.success {
  background: rgba(20, 61, 47, 0.08);
  color: #224f3f;
}

.status-summary.pending {
  background: rgba(210, 154, 60, 0.12);
  color: #8f6322;
}

.status-summary.failed {
  background: rgba(188, 82, 54, 0.12);
  color: #8a3b2b;
}

.result-view {
  overflow: hidden;
  border-radius: 16rpx;
  background: #e8eeea;
}

.result-image {
  display: block;
  width: 100%;
}

.thumb-scroll,
.reference-scroll {
  margin-top: 18rpx;
  white-space: nowrap;
}

.thumb,
.reference-thumb {
  display: inline-block;
  margin-right: 12rpx;
  overflow: hidden;
  border-radius: 12rpx;
  background: #e7eeea;
}

.thumb {
  width: 132rpx;
  height: 132rpx;
  border: 3rpx solid transparent;
}

.thumb.active {
  border-color: #103b2c;
}

.thumb image,
.reference-thumb image {
  width: 100%;
  height: 100%;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 160rpx 160rpx;
  gap: 16rpx;
  margin-top: 22rpx;
}

.info-card {
  display: grid;
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 24rpx;
}

.info-line {
  display: flex;
  justify-content: space-between;
  color: #40504a;
  font-size: 26rpx;
}

.info-line text:first-child {
  color: #7b8580;
}

.reference-section {
  margin-top: 28rpx;
}

.reference-thumb {
  width: 144rpx;
  height: 144rpx;
}

.record-btn {
  width: 100%;
  margin-top: 28rpx;
}

.promise-card {
  display: grid;
  gap: 12rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  color: #607069;
  font-size: 23rpx;
  line-height: 1.45;
}

.copy-task-btn {
  height: 64rpx;
  margin-top: 8rpx;
  border-radius: 16rpx;
  background: #143d2f;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 64rpx;
  text-align: center;
}
