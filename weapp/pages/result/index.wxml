<view class="page result-page">
  <view class="result-head">
    <view>
      <view class="title">{{task ? task.promptTitle : '生成结果'}}</view>
      <view class="muted">{{createdLabel}}</view>
    </view>
    <view class="pill">{{statusLabel}}</view>
  </view>

  <view wx:if="{{message}}" class="card message-card {{isFailed ? 'failed' : ''}}">
    <text class="message-title">{{isFailed ? '生成失败' : '提示'}}</text>
    <text>{{message}}</text>
    <text wx:if="{{isFailed}}" class="refund-note">未成功生成的任务会自动退回对应积分，可稍后换模板或重新生成。</text>
  </view>

  <view wx:if="{{currentUrl}}" class="result-view">
    <image class="result-image" mode="widthFix" src="{{currentUrl}}" bindtap="previewCurrent" />
  </view>
  <view wx:elif="{{isPending}}" class="card pending-card">
    <view class="pending-title">{{statusLabel}}</view>
    <view class="muted">通常 30-90 秒完成。你可以离开此页，作品页会同步展示生成进度。</view>
  </view>

  <view wx:if="{{task}}" class="status-summary {{isFailed ? 'failed' : (isPending ? 'pending' : 'success')}}">
    <text>{{statusLabel}}</text>
    <text>{{resultStatusDesc}}</text>
  </view>

  <scroll-view wx:if="{{images.length > 1}}" scroll-x class="thumb-scroll">
    <button wx:for="{{images}}" wx:key="url" class="thumb {{index === currentIndex ? 'active' : ''}}" data-index="{{index}}" bindtap="selectImage">
      <image mode="aspectFill" src="{{item.previewUrl}}" />
    </button>
  </scroll-view>

  <view class="action-row">
    <button class="primary-btn" bindtap="saveCurrent" disabled="{{!currentUrl}}">保存图片</button>
    <button class="ghost-btn" bindtap="goHome">{{isFailed ? '重试' : '再生成'}}</button>
    <button class="ghost-btn" bindtap="goCreate">换模板</button>
  </view>

  <view class="card info-card">
    <view class="info-line">
      <text>任务状态</text>
      <text>{{statusLabel}}</text>
    </view>
    <view class="info-line">
      <text>生成张数</text>
      <text>{{taskCount}} 张</text>
    </view>
    <view class="info-line">
      <text>消耗积分</text>
      <text>{{creditCost}}</text>
    </view>
    <view wx:if="{{latencyLabel}}" class="info-line">
      <text>生成耗时</text>
      <text>{{latencyLabel}}</text>
    </view>
  </view>

  <view class="card promise-card">
    <text>图片仅用于本次生成，不会公开展示。</text>
    <text>生成失败自动退回积分。</text>
    <text>如保存失败，可先点图片预览后长按保存。</text>
    <button wx:if="{{isFailed}}" class="copy-task-btn" bindtap="copyTaskId">复制任务编号并联系客服</button>
  </view>

  <view wx:if="{{references.length}}" class="reference-section">
    <view class="section-title">参考图</view>
    <scroll-view scroll-x class="reference-scroll">
      <button wx:for="{{references}}" wx:key="url" class="reference-thumb" data-url="{{item.previewUrl}}" bindtap="previewReference">
        <image mode="aspectFill" src="{{item.previewUrl}}" />
      </button>
    </scroll-view>
  </view>

  <button class="ghost-btn record-btn" bindtap="goRecords">查看全部记录</button>
</view>
