.flows-page {
  padding-bottom: 72rpx;
  background:
    radial-gradient(circle at top right, rgba(214, 167, 91, 0.16), transparent 40%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.login-empty,
.empty-card {
  display: grid;
  gap: 18rpx;
  padding: 42rpx 30rpx;
  text-align: center;
}

.login-empty-title,
.empty-title {
  color: #1f2824;
  font-size: 30rpx;
  font-weight: 700;
}

.login-empty-desc,
.empty-desc,
.section-extra,
.flow-meta,
.flow-status {
  color: #7b857f;
  font-size: 24rpx;
}

.login-empty-btn {
  height: 88rpx;
  margin-top: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.balance-card {
  padding: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #143c2e 0%, #1a4a37 100%);
  box-shadow: 0 18rpx 34rpx rgba(20, 60, 46, 0.18);
}

.balance-label {
  color: rgba(255, 255, 255, 0.78);
  font-size: 26rpx;
}

.balance-value {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.balance-unit {
  margin-left: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 400;
}

.section-title {
  margin-top: 32rpx;
}

.flow-list {
  display: grid;
  gap: 16rpx;
}

.flow-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
}

.flow-main {
  flex: 1;
  min-width: 0;
}

.flow-title {
  display: block;
  overflow: hidden;
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.flow-meta {
  display: flex;
  gap: 18rpx;
  margin-top: 10rpx;
}

.flow-side {
  display: grid;
  justify-items: end;
  gap: 8rpx;
}

.flow-credits {
  font-size: 30rpx;
  font-weight: 700;
}

.flow-credits.income {
  color: #d08f2d;
}

.flow-credits.expense {
  color: #1f6a50;
}
