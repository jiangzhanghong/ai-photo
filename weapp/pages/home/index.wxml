<view class="page create-home" style="padding-top: {{safeTop}}px;">
  <view class="hero-panel">
    <view class="hero-copy">
      <view class="hero-title">{{greetingTitle}}</view>
      <view class="hero-subtitle">选择模板，上传参考图，生成你的专属写真</view>
    </view>
    <view class="credit-badge" style="margin-right: {{capsuleGap}}px;">
      <text class="credit-coin">分</text>
      <view class="credit-badge-copy">
        <text class="credit-badge-label">{{user ? '积分' : '未登录'}}</text>
        <text class="credit-badge-value">{{user ? creditBalance : '--'}}</text>
      </view>
    </view>
  </view>

  <view class="card upload-card">
    <view class="upload-copy">
      <view class="card-title">上传参考图</view>
      <view class="card-subtitle">上传 1-5 张清晰正脸照，图片仅用于本次生成</view>
      <button class="upload-action" bindtap="chooseImages">+</button>
      <text class="upload-script">上传</text>
    </view>
    <view class="upload-preview-stack">
      <image class="upload-preview back" mode="aspectFill" src="{{selectedTemplateImage}}" />
      <image class="upload-preview front" mode="aspectFill" src="{{uploadedImages.length ? uploadedImages[0].previewUrl : selectedTemplateImage}}" />
      <text class="sample-flag">{{uploadedImages.length ? '已上传' : '待上传'}}</text>
    </view>
  </view>

  <view class="trust-strip">
    <text>图片不公开展示</text>
    <text>失败自动退积分</text>
    <text>作品同步账号</text>
  </view>

  <view class="section-head">
    <text class="section-title">热门模板</text>
    <button class="section-link" bindtap="openTemplatePage">查看更多</button>
  </view>
  <scroll-view scroll-x class="template-strip">
    <view class="template-track">
      <button
        wx:for="{{templates}}"
        wx:key="id"
        class="template-thumb {{item.id === selectedTemplateId ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="selectTemplate"
      >
        <image class="template-thumb-image" mode="aspectFill" src="{{item.imageUrl}}" />
        <text wx:if="{{item.id === selectedTemplateId}}" class="template-check">✓</text>
        <text class="template-thumb-title">{{item.title}}</text>
      </button>
    </view>
  </scroll-view>

  <view class="selected-template-card">
    <image class="selected-template-cover" mode="aspectFill" src="{{selectedTemplateImage}}" />
    <view class="selected-template-copy">
      <text class="selected-template-label">已选模板</text>
      <text class="selected-template-title">{{selectedTemplateTitle}}</text>
      <text class="selected-template-desc">{{selectedTemplatePromptText}}</text>
    </view>
  </view>

  <button class="settings-summary" bindtap="openSettingsPanel">
    <view class="settings-summary-item">
      <text class="settings-summary-label">画面比例</text>
      <text class="settings-summary-value">{{selectedRatio}}</text>
    </view>
    <view class="settings-summary-divider"></view>
    <view class="settings-summary-item">
      <text class="settings-summary-label">清晰度</text>
      <text class="settings-summary-value">{{selectedResolution}}</text>
    </view>
    <text class="settings-summary-arrow">›</text>
  </button>

  <view class="section-block">
    <view class="count-head">
      <view>
        <view class="section-title">生成数量</view>
        <view class="count-hint">消耗 {{estimatedCost}} 积分</view>
      </view>
      <view class="count-stepper">
        <button class="step-btn" bindtap="decreaseCount">−</button>
        <text class="step-value">{{count}}</text>
        <button class="step-btn" bindtap="increaseCount">+</button>
      </view>
    </view>
  </view>

  <view class="generate-summary">
    <view class="summary-title-row">
      <text class="summary-title">生成确认</text>
      <text class="summary-time">{{estimatedTimeLabel}}</text>
    </view>
    <view class="summary-grid">
      <view class="summary-item">
        <text class="summary-label">模板</text>
        <text class="summary-value">{{selectedTemplateTitle}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">比例 / 清晰度</text>
        <text class="summary-value">{{selectedRatio}} · {{selectedResolution}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">尺寸</text>
        <text class="summary-value">{{requestSize}}</text>
      </view>
      <view class="summary-item">
        <text class="summary-label">数量 / 积分</text>
        <text class="summary-value">{{count}} 张 · {{estimatedCost}} 积分</text>
      </view>
    </view>
    <view wx:if="{{creditShortage}}" class="summary-warning">
      本次还差 {{creditShortage}} 积分，充值后即可继续生成。
    </view>
  </view>

  <button class="generate-btn" loading="{{submitting}}" disabled="{{generateButtonDisabled}}" bindtap="submitTask">
    {{generateButtonText}}
  </button>
  <view class="remaining-text">{{generateHint}}</view>
  <view wx:if="{{message}}" class="message-line">{{message}}</view>

  <view wx:if="{{uploadedImages.length}}" class="selected-images">
    <view wx:for="{{uploadedImages}}" wx:key="id" class="selected-image-tile">
      <image class="selected-image" mode="aspectFill" src="{{item.previewUrl}}" />
      <button class="remove-btn" data-id="{{item.id}}" bindtap="removeImage">×</button>
    </view>
  </view>

  <view wx:if="{{settingsPanelVisible}}" class="settings-mask" catchtap="closeSettingsPanel">
    <view class="settings-sheet" catchtap="noop">
      <view class="settings-sheet-head">
        <view>
          <view class="settings-sheet-title">生成参数</view>
          <view class="settings-sheet-desc">选模板后会自动带入推荐参数，也可以手动调整。</view>
        </view>
        <button class="settings-close" bindtap="closeSettingsPanel">×</button>
      </view>

      <view class="settings-group">
        <view class="settings-group-title">画面比例</view>
        <view class="ratio-list">
          <button
            wx:for="{{ratioOptions}}"
            wx:key="value"
            class="ratio-option {{item.value === selectedRatio ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectRatio"
          >
            <view>
              <view class="ratio-option-label">{{item.label}}</view>
              <view class="ratio-option-usage">{{item.usage}}</view>
            </view>
            <text wx:if="{{item.value === selectedRatio}}" class="ratio-check">✓</text>
          </button>
        </view>
      </view>

      <view class="settings-group">
        <view class="settings-group-title">清晰度</view>
        <view class="resolution-row">
          <button
            wx:for="{{resolutionOptions}}"
            wx:key="value"
            class="resolution-chip {{item.value === selectedResolution ? 'active' : ''}}"
            data-value="{{item.value}}"
            bindtap="selectResolution"
          >
            <text class="resolution-label">{{item.label}}</text>
            <text class="resolution-desc">{{item.desc}}</text>
          </button>
        </view>
      </view>

      <button class="settings-done" bindtap="closeSettingsPanel">完成</button>
    </view>
  </view>
</view>
