.member-card {
  padding: 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #0c3024 0%, #174d3b 100%);
  color: #fff;
}

.member-top {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.16);
  font-size: 34rpx;
  font-weight: 700;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 32rpx;
  font-weight: 700;
}

.phone {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
}

.plan-pill {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 22rpx;
}

.credit-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.credit-row view {
  padding: 18rpx;
  border-radius: 14rpx;
  background: rgba(255, 255, 255, 0.10);
}

.credit-row text {
  display: block;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
}

.credit-row .value {
  display: block;
  margin-top: 8rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.login-card {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
  padding: 24rpx;
}

.field {
  height: 82rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dbe3de;
  border-radius: 12rpx;
  background: #fbfcfb;
}

.code-row {
  display: grid;
  grid-template-columns: 1fr 200rpx;
  gap: 14rpx;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 180rpx;
  gap: 14rpx;
  margin-top: 24rpx;
}

.plan-title {
  margin-top: 34rpx;
}

.plan-list {
  display: grid;
  gap: 16rpx;
}

.plan-card {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx;
}

.plan-name {
  margin-bottom: 6rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.price {
  color: #103b2c;
  font-size: 34rpx;
  font-weight: 800;
}
