.create-home {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(215, 193, 153, 0.20), transparent 38%),
    linear-gradient(180deg, #faf6ef 0%, #f6f3ec 100%);
}

.hero-panel {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 34rpx 28rpx 116rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #0d2f24 0%, #143d2f 68%, #174332 100%);
}

.hero-copy {
  max-width: 410rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.1;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.80);
  font-size: 24rpx;
}

.credit-badge {
  display: grid;
  justify-items: end;
  gap: 8rpx;
  min-width: 112rpx;
}

.credit-badge-label {
  color: rgba(255, 230, 179, 0.78);
  font-size: 20rpx;
}

.credit-badge-value {
  color: #f7d89f;
  font-size: 42rpx;
  font-weight: 700;
}

.upload-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: -82rpx;
  padding: 28rpx;
}

.upload-copy {
  flex: 1;
  min-width: 0;
}

.card-title,
.section-title {
  color: #1f2723;
  font-size: 32rpx;
  font-weight: 700;
}

.card-subtitle,
.count-hint,
.section-link,
.remaining-text,
.message-line {
  color: #7d857f;
  font-size: 24rpx;
}

.card-subtitle {
  margin-top: 12rpx;
}

.upload-action {
  width: 88rpx;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #174837 0%, #113829 100%);
  color: #ffffff;
  font-size: 54rpx;
  line-height: 88rpx;
}

.upload-preview-stack {
  position: relative;
  width: 214rpx;
  height: 214rpx;
  flex: none;
}

.upload-preview {
  position: absolute;
  overflow: hidden;
  border: 6rpx solid #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 18rpx 30rpx rgba(18, 45, 34, 0.12);
}

.upload-preview.back {
  top: 18rpx;
  right: 8rpx;
  width: 148rpx;
  height: 196rpx;
  transform: rotate(8deg);
  opacity: 0.92;
}

.upload-preview.front {
  right: 22rpx;
  bottom: 6rpx;
  width: 144rpx;
  height: 188rpx;
  transform: rotate(-3deg);
}

.sample-flag {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  min-width: 70rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 34rpx;
}

.template-strip {
  margin-top: 18rpx;
  white-space: nowrap;
}

.template-track {
  display: inline-flex;
  gap: 16rpx;
  padding-right: 12rpx;
}

.template-thumb {
  width: 132rpx;
  text-align: center;
}

.template-thumb-image {
  width: 132rpx;
  height: 168rpx;
  border: 2rpx solid transparent;
  border-radius: 22rpx;
  background: #ebe7df;
}

.template-thumb.active .template-thumb-image {
  border-color: #123b2c;
  box-shadow: 0 12rpx 24rpx rgba(18, 59, 44, 0.12);
}

.template-thumb-title {
  display: block;
  margin-top: 12rpx;
  overflow: hidden;
  color: #4b544f;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-block {
  margin-top: 34rpx;
}

.ratio-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin-top: 18rpx;
}

.ratio-chip {
  height: 74rpx;
  border: 2rpx solid transparent;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #55605a;
  font-size: 26rpx;
}

.ratio-chip.active {
  border-color: #163d2f;
  background: #ffffff;
  color: #163d2f;
  font-weight: 700;
}

.count-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.count-hint {
  margin-top: 10rpx;
}

.count-stepper {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.step-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6e7771;
  font-size: 32rpx;
  line-height: 52rpx;
}

.step-value {
  min-width: 24rpx;
  color: #1d2823;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.generate-btn {
  height: 92rpx;
  margin-top: 40rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 92rpx;
  text-align: center;
}

.remaining-text,
.message-line {
  margin-top: 18rpx;
  text-align: center;
}

.selected-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.selected-image-tile {
  position: relative;
  height: 180rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.selected-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.44);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
}
