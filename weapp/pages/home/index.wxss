.create-home {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(215, 193, 153, 0.22), transparent 38%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.hero-panel {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  min-height: 248rpx;
  padding: 34rpx 28rpx 120rpx;
  border-radius: 38rpx;
  background: linear-gradient(145deg, #0d2f24 0%, #143d2f 68%, #174332 100%);
  box-shadow: 0 20rpx 40rpx rgba(15, 48, 36, 0.18);
}

.hero-copy {
  max-width: 410rpx;
}

.hero-title {
  color: #ffffff;
  font-size: 60rpx;
  font-weight: 700;
  line-height: 1.1;
}

.hero-subtitle {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.80);
  font-size: 24rpx;
}

.credit-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.credit-coin {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #f1c974 0%, #d79f43 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 36rpx;
  text-align: center;
}

.credit-badge-copy {
  display: grid;
  gap: 4rpx;
}

.credit-badge-label {
  color: rgba(255, 230, 179, 0.78);
  font-size: 20rpx;
}

.credit-badge-value {
  color: #f7d89f;
  font-size: 42rpx;
  font-weight: 700;
}

.upload-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: -88rpx;
  padding: 30rpx 28rpx 24rpx;
}

.upload-copy {
  flex: 1;
  min-width: 0;
}

.card-title,
.section-title {
  color: #1f2723;
  font-size: 32rpx;
  font-weight: 700;
}

.card-subtitle,
.count-hint,
.section-link,
.remaining-text,
.message-line {
  color: #7d857f;
  font-size: 22rpx;
}

.card-subtitle {
  margin-top: 14rpx;
}

.upload-action {
  width: 88rpx;
  height: 88rpx;
  margin-top: 34rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #174837 0%, #113829 100%);
  color: #ffffff;
  font-size: 54rpx;
  line-height: 88rpx;
  text-align: center;
  box-shadow: 0 16rpx 28rpx rgba(16, 59, 44, 0.14);
}

.upload-script {
  position: absolute;
  left: 190rpx;
  bottom: 38rpx;
  color: rgba(225, 192, 138, 0.9);
  font-size: 62rpx;
  font-style: italic;
  font-family: "Times New Roman", serif;
  line-height: 1;
}

.upload-preview-stack {
  position: relative;
  width: 228rpx;
  height: 214rpx;
  flex: none;
}

.upload-preview {
  position: absolute;
  overflow: hidden;
  border: 6rpx solid #ffffff;
  border-radius: 22rpx;
  box-shadow: 0 18rpx 30rpx rgba(18, 45, 34, 0.12);
}

.upload-preview.back {
  top: 18rpx;
  right: 4rpx;
  width: 154rpx;
  height: 194rpx;
  transform: rotate(8deg);
  opacity: 0.92;
}

.upload-preview.front {
  right: 18rpx;
  bottom: 4rpx;
  width: 148rpx;
  height: 190rpx;
  transform: rotate(-3deg);
}

.sample-flag {
  position: absolute;
  right: 18rpx;
  bottom: 18rpx;
  z-index: 2;
  min-width: 70rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(0, 0, 0, 0.45);
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
}

.template-strip {
  margin-top: 14rpx;
  white-space: nowrap;
}

.template-track {
  display: inline-flex;
  gap: 14rpx;
  padding-right: 12rpx;
}

.template-thumb {
  width: 116rpx;
  text-align: center;
}

.template-thumb-image {
  width: 116rpx;
  height: 148rpx;
  border: 2rpx solid transparent;
  border-radius: 18rpx;
  background: #ebe7df;
}

.template-thumb.active .template-thumb-image {
  border-color: #123b2c;
  box-shadow: 0 12rpx 24rpx rgba(18, 59, 44, 0.12);
}

.template-thumb-title {
  display: block;
  margin-top: 10rpx;
  overflow: hidden;
  color: #4b544f;
  font-size: 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.section-block {
  margin-top: 34rpx;
}

.ratio-row,
.resolution-row {
  display: grid;
  gap: 18rpx;
  margin-top: 18rpx;
}

.ratio-row {
  grid-template-columns: repeat(3, 1fr);
}

.resolution-row {
  grid-template-columns: repeat(2, 1fr);
}

.ratio-chip {
  height: 68rpx;
  border: 2rpx solid transparent;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #55605a;
  font-size: 26rpx;
}

.ratio-chip.active {
  border-color: #163d2f;
  background: #ffffff;
  color: #163d2f;
  font-weight: 700;
}

.resolution-chip {
  display: grid;
  gap: 6rpx;
  align-content: center;
  height: 86rpx;
  border: 2rpx solid transparent;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #53605a;
  text-align: center;
}

.resolution-chip.active {
  border-color: #163d2f;
  background: #ffffff;
  color: #163d2f;
}

.resolution-label {
  font-size: 28rpx;
  font-weight: 700;
}

.resolution-desc {
  color: #7d857f;
  font-size: 20rpx;
}

.count-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.count-hint {
  margin-top: 10rpx;
}

.count-stepper {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.step-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #6e7771;
  font-size: 32rpx;
  line-height: 52rpx;
}

.step-value {
  min-width: 24rpx;
  color: #1d2823;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.generate-btn {
  height: 92rpx;
  margin-top: 38rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 92rpx;
  text-align: center;
}

.generate-btn[disabled] {
  background: #d8ded9;
  color: #7f8a84;
  box-shadow: none;
}

.remaining-text,
.message-line {
  margin-top: 20rpx;
  text-align: center;
}

.remaining-value {
  color: #c79236;
  font-weight: 700;
}

.selected-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 30rpx;
}

.selected-image-tile {
  position: relative;
  height: 180rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.selected-image {
  width: 100%;
  height: 100%;
}

.remove-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.44);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 40rpx;
  text-align: center;
}
