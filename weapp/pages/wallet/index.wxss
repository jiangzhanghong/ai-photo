.wallet-page {
  padding-bottom: 150rpx;
  background:
    radial-gradient(circle at top center, rgba(223, 199, 160, 0.16), transparent 42%),
    linear-gradient(180deg, #fbf7f0 0%, #f4efe6 100%);
}

.login-empty {
  display: grid;
  gap: 18rpx;
  padding: 40rpx 28rpx;
  text-align: center;
}

.login-empty-title {
  color: #1f2824;
  font-size: 30rpx;
  font-weight: 700;
}

.login-empty-desc {
  color: #7b857f;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-empty-btn {
  height: 88rpx;
  margin-top: 8rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #174b39 0%, #103728 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  text-align: center;
}

.balance-card {
  position: relative;
  overflow: hidden;
  padding: 28rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #143c2e 0%, #1a4a37 100%);
  box-shadow: 0 18rpx 34rpx rgba(20, 60, 46, 0.18);
}

.balance-label {
  color: rgba(255, 255, 255, 0.82);
  font-size: 26rpx;
}

.balance-value {
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 68rpx;
  font-weight: 700;
  line-height: 1;
}

.balance-unit {
  margin-left: 8rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  font-weight: 400;
}

.balance-mark {
  position: absolute;
  right: 34rpx;
  top: 18rpx;
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 50%;
  color: rgba(255, 255, 255, 0.10);
  font-size: 92rpx;
  font-weight: 700;
  line-height: 112rpx;
  text-align: center;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 22rpx;
}

.quick-card {
  display: grid;
  gap: 8rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
  text-align: left;
}

.quick-icon {
  display: inline-grid;
  place-items: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 12rpx;
  background: rgba(20, 61, 47, 0.10);
  color: #143d2f;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-icon.gold {
  background: rgba(216, 165, 81, 0.14);
  color: #c28a2e;
}

.quick-title {
  color: #1f2824;
  font-size: 28rpx;
  font-weight: 700;
}

.quick-subtitle,
.package-bonus,
.record-time,
.record-status {
  color: #7b857f;
  font-size: 22rpx;
}

.section-title {
  margin-top: 28rpx;
  color: #1f2824;
  font-size: 32rpx;
  font-weight: 700;
}

.package-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-top: 18rpx;
}

.package-card {
  display: grid;
  gap: 12rpx;
  align-content: start;
  min-height: 176rpx;
  padding: 22rpx 18rpx;
  border: 2rpx solid transparent;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.90);
  text-align: left;
}

.package-card.active {
  border-color: #d9aa57;
  background: linear-gradient(180deg, #fffaf0 0%, #fff3d8 100%);
}

.package-price {
  color: #1f2824;
  font-size: 30rpx;
  font-weight: 700;
}

.package-credits {
  color: #6f4e17;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.1;
}

.recharge-btn {
  height: 90rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #164836 0%, #113829 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 90rpx;
  text-align: center;
}

.section-gap {
  margin-top: 34rpx;
}

.record-list {
  display: grid;
  gap: 16rpx;
  margin-top: 18rpx;
}

.record-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-title,
.record-credits {
  color: #1f2824;
  font-size: 28rpx;
}

.record-bottom {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 10rpx;
}

.record-amount {
  color: #7b857f;
  font-size: 22rpx;
}

.record-credits {
  color: #d08f2d;
  font-weight: 700;
}

.record-side {
  display: grid;
  justify-items: end;
  gap: 8rpx;
}
